{
  "name": "sanati",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:mobile": "tsc && vite build --mode mobile",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src --max-warnings=0",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:android": "npm run build:mobile && cap sync android",
    "cap:ios": "npm run build:mobile && cap sync ios",
    "android:debug": "npm run cap:android && cd android && gradlew.bat assembleDebug --no-daemon",
    "android:release": "npm run cap:android && cd android && gradlew.bat bundleRelease --no-daemon"
  },
  "dependencies": {
    "@fontsource/cairo": "^5.2.7",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.6.3",
    "framer-motion": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^6.18.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
